# Analysis environment (recreate via analysis/requirements.txt)
analysis/.venv/

# Python cache
__pycache__/
*.pyc
analysis/.pytest_cache/

# Synthetic data — dev-only, generated by synth.py, never released
analysis/data/synthetic/

# Sensitive inputs — never released:
#   findings.jsonl = AIPR-generated weaknesses about named papers
#   *.pdf          = manuscript PDFs (redistribution not permitted)
analysis/data/**/findings.jsonl
analysis/data/**/*.pdf

# Generated analysis outputs (regenerate with `python cli.py all`)
analysis/results/*.json
paper/figures/*.pdf
paper/figures/*.png
paper/tables/*.tex
paper/macros/results_macros.tex
paper/macros/sim_macros.tex
paper/macros/secondary_macros.tex
paper/macros/SYNTHETIC.flag
paper/prereg_verbatim.tex

# LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.toc
paper/*.fls
paper/*.fdb_latexmk
paper/pass*.log
paper/bibtex.log
paper/main.pdf
paper/main-anon.pdf
paper/main_nmi.pdf
paper/ANONYMOUS.flag

# Scratch / tooling
paper/main.extracted.txt
.delegate/
